            RowBox[{"\[CapitalLambda]", "^", "2"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{
           RowBox[{"2", "Pi"}], "-", " ", 
           RowBox[{"ArcCos", "[", 
            RowBox[{"u", "/", 
             RowBox[{"\[CapitalLambda]", "^", "2"}]}], "]"}]}]}], "}"}]}], 
