Cell[BoxData[{
 RowBox[{
  RowBox[{"bpnf0", "[", 
   RowBox[{"u_", ",", "\[CapitalLambda]_"}], "]"}], ":=", 
  RowBox[{"ComplexListPlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"I", " ", 
        RowBox[{"ArcCos", "[", 
         RowBox[{"u", "/", 
          RowBox[{"\[CapitalLambda]", "^", "2"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"2", "Pi", " ", "I"}], "-", 
        RowBox[{"I", " ", 
         RowBox[{"ArcCos", "[", 
          RowBox[{"u", "/", 
           RowBox[{"\[CapitalLambda]", "^", "2"}]}], "]"}]}]}]}], "}"}], "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<i \[Pi]-i  arccos[u/\[CapitalLambda]^2]\>\"", 
       ",", "\"\<i \[Pi]+i arccos[u/\[CapitalLambda]^2]\>\""}], "}"}]}], ",", 
    
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", 
         RowBox[{"2", 
          RowBox[{"(*", 
           RowBox[{"5", "/", "3"}], "*)"}], "Pi"}]}], "}"}]}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bcnf0", "[", 
   RowBox[{"u_", ",", "\[CapitalLambda]_"}], "]"}], ":=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
